# Hugging Face token (optional for public models like Ornith, required for gated ones like Llama)
# Get yours at https://huggingface.co/settings/tokens
HUGGING_FACE_HUB_TOKEN=

# LiteLLM master key (must start with 'sk-'). Used to generate virtual keys for users.
LITELLM_MASTER_KEY=sk-chnge-me-to-something-random

# PostgreSQL password
POSTGRES_PASSWORD=chnge-me-too

# Model to serve (default: Ornith-1.0-35B-FP8)
# Options: deepreinforce-ai/Ornith-1.0-35B-FP8, deepreinforce-ai/Ornith-1.0-9B, etc.
MODEL=deepreinforce-ai/Ornith-1.0-35B-FP8
