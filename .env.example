# Hugging Face token (REQUIRED for Gemma 4 — it's a gated model)
# 1. Accept the license at https://huggingface.co/google/gemma-4-31B-it
# 2. Generate a token at https://huggingface.co/settings/tokens
HUGGING_FACE_HUB_TOKEN=

# LiteLLM master key (must start with 'sk-'). Used to generate virtual keys for users.
LITELLM_MASTER_KEY=sk-chnge-me-to-something-random

# PostgreSQL password
POSTGRES_PASSWORD=chnge-me-too

# Model to serve
# Default: RedHatAI/gemma-4-31B-it-FP8-block (FP8 quantized, ~31GB VRAM on this model)
# Alternatives:
#   RedHatAI/gemma-4-31B-it-FP8-block
#   google/gemma-4-31B-it                  (BF16, ~62GB, needs more VRAM)
#   deepreinforce-ai/Ornith-1.0-35B-FP8    (set MODEL= and use docker-compose.ornith.yaml)
MODEL=RedHatAI/gemma-4-31B-it-FP8-block
